# ── LLM 태깅 모드 ─────────────────────────────────────────────
# 미설정 시 자동 선택: claude CLI(구독, 무료) → ANTHROPIC_API_KEY(API) → 휴리스틱
# 강제하려면: cli | api | heuristic
TAGGER_MODE=

# [cli 모드] Claude Code CLI 명령 (기본 'claude'). PATH에 없으면 절대경로 지정
CLAUDE_CLI_CMD=

# [api 모드] Anthropic API 키 + 모델 (기본 claude-haiku-4-5)
ANTHROPIC_API_KEY=
TAGGER_MODEL=claude-haiku-4-5

# ── 수집 소스 ────────────────────────────────────────────────
# 네이버 오픈 API — https://developers.naver.com/apps 에서 무료 발급 (블로그/카페 검색)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 알림/스케줄 ──────────────────────────────────────────────
# 일일 리포트를 보낼 웹훅 (Slack incoming webhook 호환: {"text": "..."} POST)
WEBHOOK_URL=

# 스케줄러 기본 주기(시간). 이후에는 대시보드 UI에서 변경
DEFAULT_INTERVAL_HOURS=24

# DB 경로 오버라이드 (기본값: <repo>/data/feedback-radar.db)
# DB_PATH=
